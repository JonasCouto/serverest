{
  "name": "serverest",
  "version": "1.0.0",
  "description": "Automação de testes para ServeRest — Cypress 14 + Cucumber BDD",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:api": "cypress run --spec 'cypress/api/**/*.feature'",
    "test:e2e": "cypress run --spec 'cypress/e2e/**/*.feature'",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "lint": "eslint cypress/",
    "format": "prettier --write cypress/"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": false,
    "stepDefinitions": [
      "cypress/api/**/*.js",
      "cypress/e2e/**/*.js",
      "cypress/support/step_definitions/**/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@faker-js/faker": "^10.5.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "cypress": "^14.5.4",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-cypress": "^6.4.2",
    "prettier": "^3.9.5"
  }
}
